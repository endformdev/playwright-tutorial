# Zero-config mode works without a `.env` file.
# If you leave DATABASE_URL unset, the app uses the shared Durable Object SQLite proxy.
# If you leave AUTH_SECRET unset, the app uses a built-in demo secret.
# Note: if you do add this file, it must be `.env`, not `.env.local`, without further configuration changes.

# Optional: switch to local SQLite with `pnpm db:setup`
# DATABASE_URL=./local-sqlite-database.db

# Optional: point directly at your Durable Object sqlite-proxy URL
# DATABASE_URL=https://your-durable-object-proxy.workers.dev

# Optional: Turso connection
# DATABASE_URL=libsql://your-database-name.turso.io
# DATABASE_AUTH_TOKEN=your-auth-token-here

BASE_URL=http://localhost:3000
# AUTH_SECRET=replace-me-for-non-demo-use
